       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"c\[Mu]T", "[", "q", "]"}], ",", 
              RowBox[{"params", "[", 
               RowBox[{"[", "x", "]"}], "]"}]}], "]"}], "*", 
            RowBox[{
             RowBox[{"D", "[", 
              RowBox[{
               RowBox[{"c\[Mu]T", "[", "q", "]"}], ",", 
               RowBox[{"params", "[", 
                RowBox[{"[", "y", "]"}], "]"}]}], "]"}], "/", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"Sqrt", "[", 
                 RowBox[{
                  RowBox[{"1", "/", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"2", "q"}], "+", "1"}], ")"}]}], "*", 
                  RowBox[{"cTT", "[", "q", "]"}], "*", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"w", "^", 
                    RowBox[{"(", 
                    RowBox[{"-", "1"}], ")"}]}], "*", 
                    RowBox[{"Exp", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"q", "/", "lvar"}], ")"}], "^", "2"}], "]"}]}], 
                   ")"}]}], "]"}], ")"}], "^", "2"}], ")"}]}]}], ",", 
           RowBox[{"{", 
            RowBox[{"q", ",", "2", ",", "lvar"}], "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "1", ",", "n"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"y", ",", "1", ",", "n"}], "}"}]}], "]"}], "+", "prior"}], 
      "]"}], "[", 
